// Skillpay Prisma Schema
// Database: PostgreSQL (Supabase / Railway)
// Generator: Prisma Client (TypeScript)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  HOMEOWNER
  ARTISAN
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

enum JobStatus {
  DRAFT
  PENDING
  PUBLISHED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum BookingStatus {
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentGateway {
  STRIPE
  PAYPAL
  WALLET
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  WALLET
  PAYPAL
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  WITHDRAWAL
  REFUND
}

enum NotificationType {
  JOB
  APPLICATION
  BOOKING
  PAYMENT
  REVIEW
  VERIFICATION
  GENERAL
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum VerificationDocumentType {
  NATIONAL_ID
  DRIVERS_LICENSE
  PASSPORT
  UTILITY_BILL
  BUSINESS_REGISTRATION
  PROFESSIONAL_CERTIFICATE
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id             String     @id @default(uuid())
  supabaseUserId String     @unique @map("supabase_user_id")
  email          String     @unique
  phone          String?
  role           Role       @default(HOMEOWNER)
  status         UserStatus @default(ACTIVE)
  isVerified     Boolean    @default(false) @map("is_verified")
  fcmToken       String?    @map("fcm_token")
  lastLogin      DateTime?  @map("last_login")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  // Relations
  homeowner            Homeowner?
  artisan              Artisan?
  sentMessages         Message[]          @relation("MessageSender")
  notifications        Notification[]
  reportsMade          Report[]           @relation("ReportedBy")
  reportsReceived      Report[]           @relation("ReportedUser")
  wallet               Wallet?
  adminLogs            AdminLog[]
  addresses            Address[]

  @@map("users")
}

// ─── Homeowners ───────────────────────────────────────────────────────────────

model Homeowner {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  fullName       String   @map("full_name")
  gender         String?
  dob            DateTime?
  profilePhoto   String?  @map("profile_photo")
  defaultAddress String?  @map("default_address")
  latitude       Float?
  longitude      Float?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs      Job[]
  bookings  Booking[]
  reviews   Review[]
  payments  Payment[]

  @@map("homeowners")
}

// ─── Artisans ─────────────────────────────────────────────────────────────────

model Artisan {
  id                   String             @id @default(uuid())
  userId               String             @unique @map("user_id")
  businessName         String?            @map("business_name")
  fullName             String             @map("full_name")
  bio                  String?
  experience           String?
  yearsExperience      Int                @default(0) @map("years_experience")
  hourlyRate           Decimal?           @db.Decimal(10, 2) @map("hourly_rate")
  verificationStatus   VerificationStatus @default(UNVERIFIED) @map("verification_status")
  profilePhoto         String?            @map("profile_photo")
  averageRating        Float              @default(0) @map("average_rating")
  completedJobs        Int                @default(0) @map("completed_jobs")
  latitude             Float?
  longitude            Float?
  availabilityStatus   AvailabilityStatus @default(AVAILABLE) @map("availability_status")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  // Relations
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories            ArtisanCategory[]
  applications          JobApplication[]
  bookings              Booking[]
  reviews               Review[]
  verificationDocuments VerificationDocument[]
  payments              Payment[]

  @@map("artisans")
}

// ─── Categories ───────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  icon        String?
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  artisanCategories ArtisanCategory[]
  jobs              Job[]

  @@map("categories")
}

// ─── Artisan Categories (pivot) ───────────────────────────────────────────────

model ArtisanCategory {
  id         String   @id @default(uuid())
  artisanId  String   @map("artisan_id")
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  artisan  Artisan  @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([artisanId, categoryId])
  @@map("artisan_categories")
}

// ─── Addresses ────────────────────────────────────────────────────────────────

model Address {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  label     String   // e.g. "Home", "Office"
  address   String
  latitude  Float?
  longitude Float?
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// ─── Jobs ─────────────────────────────────────────────────────────────────────

model Job {
  id            String    @id @default(uuid())
  homeownerId   String    @map("homeowner_id")
  categoryId    String?   @map("category_id")
  title         String
  description   String
  budget        Decimal   @db.Decimal(12, 2)
  preferredDate DateTime? @map("preferred_date")
  status        JobStatus @default(PENDING)
  latitude      Float?
  longitude     Float?
  address       String?
  images        String[]  @default([])
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  homeowner    Homeowner        @relation(fields: [homeownerId], references: [id], onDelete: Cascade)
  category     Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  applications JobApplication[]
  booking      Booking?
  conversation Conversation?

  @@map("jobs")
}

// ─── Job Applications ─────────────────────────────────────────────────────────

model JobApplication {
  id                String            @id @default(uuid())
  jobId             String            @map("job_id")
  artisanId         String            @map("artisan_id")
  price             Decimal           @db.Decimal(12, 2)
  estimatedDuration String?           @map("estimated_duration")
  proposal          String
  status            ApplicationStatus @default(PENDING)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  job     Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  artisan Artisan @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  booking Booking?

  @@unique([jobId, artisanId])
  @@map("job_applications")
}

// ─── Bookings ─────────────────────────────────────────────────────────────────

model Booking {
  id               String        @id @default(uuid())
  jobId            String        @unique @map("job_id")
  applicationId    String        @unique @map("application_id")
  artisanId        String        @map("artisan_id")
  homeownerId      String        @map("homeowner_id")
  startDate        DateTime?     @map("start_date")
  completionDate   DateTime?     @map("completion_date")
  status           BookingStatus @default(CONFIRMED)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  job         Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  artisan     Artisan        @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  homeowner   Homeowner      @relation(fields: [homeownerId], references: [id], onDelete: Cascade)
  payment     Payment?
  review      Review?
  reports     Report[]

  @@map("bookings")
}

// ─── Conversations ────────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(uuid())
  jobId     String   @unique @map("job_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  job      Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("conversations")
}

// ─── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  message        String
  attachment     String[] @default([])
  seen           Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

model Review {
  id          String   @id @default(uuid())
  bookingId   String   @unique @map("booking_id")
  artisanId   String   @map("artisan_id")
  homeownerId String   @map("homeowner_id")
  rating      Int      // 1–5
  review      String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  artisan   Artisan   @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  homeowner Homeowner @relation(fields: [homeownerId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id            String         @id @default(uuid())
  bookingId     String         @unique @map("booking_id")
  homeownerId   String         @map("homeowner_id")
  artisanId     String         @map("artisan_id")
  reference     String         @unique
  amount        Decimal        @db.Decimal(12, 2)
  gateway       PaymentGateway
  status        PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod  @map("payment_method")
  gatewayRef    String?        @map("gateway_ref")  // Stripe PaymentIntent or PayPal order ID
  metadata      Json?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  homeowner Homeowner @relation(fields: [homeownerId], references: [id], onDelete: Cascade)
  artisan   Artisan   @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── Wallets ──────────────────────────────────────────────────────────────────

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

// ─── Wallet Transactions ──────────────────────────────────────────────────────

model WalletTransaction {
  id          String                @id @default(uuid())
  walletId    String                @map("wallet_id")
  amount      Decimal               @db.Decimal(12, 2)
  type        WalletTransactionType
  reference   String                @unique
  description String?
  createdAt   DateTime              @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("wallet_transactions")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  title     String
  body      String
  type      NotificationType @default(GENERAL)
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Reports ──────────────────────────────────────────────────────────────────

model Report {
  id             String       @id @default(uuid())
  reportedById   String       @map("reported_by")
  reportedUserId String       @map("reported_user")
  bookingId      String?      @map("booking_id")
  reason         String
  status         ReportStatus @default(OPEN)
  adminNote      String?      @map("admin_note")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  reportedBy   User     @relation("ReportedBy", fields: [reportedById], references: [id], onDelete: Cascade)
  reportedUser User     @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)
  booking      Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@map("reports")
}

// ─── Verification Documents ───────────────────────────────────────────────────

model VerificationDocument {
  id         String                   @id @default(uuid())
  artisanId  String                   @map("artisan_id")
  type       VerificationDocumentType
  fileUrl    String                   @map("file_url")
  status     VerificationStatus       @default(PENDING)
  adminNote  String?                  @map("admin_note")
  createdAt  DateTime                 @default(now()) @map("created_at")
  updatedAt  DateTime                 @updatedAt @map("updated_at")

  artisan Artisan @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@map("verification_documents")
}

// ─── Admin Logs ───────────────────────────────────────────────────────────────

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String   @map("admin_id")
  action    String
  table     String?
  recordId  String?  @map("record_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_logs")
}
